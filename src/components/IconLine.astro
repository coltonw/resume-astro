---
import type { IconLine } from "../content/sections";
import { ICONS, type TextIcon } from "../content/icons";

interface Props {
  iconLine: IconLine;
}
const { iconLine } = Astro.props;

const ICON_BASE = "flex-none w-7 h-7 mx-1.5 fill-current";

function isText(ref: unknown): ref is TextIcon {
  return typeof ref === "object" && ref !== null && "label" in ref;
}
---

<!--
  Layout: title on the left, date + separator + icons on the right.
  Desktop (sm and up): single horizontal row with title and icon-row
  vertically centered.
  Mobile: title on its own line, full-width row below it that wraps if needed.
  The icon row has no fixed height so wrapping never overlaps the next paragraph.
-->
<div
  class="mt-8 mb-4 flex flex-col gap-x-3 gap-y-1 sm:flex-row sm:items-center sm:justify-between"
>
  <h2 class="text-base leading-tight font-black text-stone-800 sm:text-lg">
    {iconLine.title}
  </h2>
  <div
    class="-mx-1.5 flex flex-row flex-wrap items-center justify-start gap-y-1 sm:justify-end"
  >
    <div
      class="mr-2 ml-1.5 text-sm font-semibold whitespace-nowrap text-stone-800"
    >
      {iconLine.date}
    </div>
    <div class="w-2 border-t-2 border-stone-400"></div>
    {
      iconLine.icons.map((ref) => {
        if (isText(ref)) {
          return (
            <a title={ref.title} href={ref.href} class="flex items-center">
              <div
                class:list={[ref.labelClass ?? "mx-2 flex-none text-stone-800"]}
              >
                {ref.label}
              </div>
            </a>
          );
        }
        const icon = ICONS[ref];
        const Component = icon.component;
        return (
          <a title={icon.title} href={icon.href} class="flex items-center">
            <Component class:list={[ICON_BASE, icon.extraClass]} />
          </a>
        );
      })
    }
  </div>
</div>
