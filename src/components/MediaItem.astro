---
import type { Media } from "../content/sections";
import EmbeddedVideo from "./islands/EmbeddedVideo.svelte";

interface Props {
  media: Media;
}
const { media } = Astro.props;
---

{
  media.kind === "video" && (
    <EmbeddedVideo
      client:visible
      webm={media.webm}
      mp4={media.mp4}
      width={media.width}
      height={media.height}
      preload={media.preload ?? false}
    />
  )
}

{
  media.kind === "image" && (
    <picture>
      <source srcset={media.src} />
      <img
        src={media.fallback}
        class="my-6 border-2 border-stone-200"
        alt={media.alt}
        width={media.width}
        height={media.height}
      />
    </picture>
  )
}

{
  media.kind === "audio" && (
    <Fragment>
      <audio src={media.src} controls class="w-full" />
      {media.caption && <div class="text-center text-xs">{media.caption}</div>}
    </Fragment>
  )
}
